rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    
    // Check if user has global superadmin role
    function isGlobalAdmin() {
      return request.auth != null && (
        (request.auth.token.keys().hasAny(['role']) && request.auth.token.role == 'superadmin') || 
        request.auth.token.email == 'clickerplatform@gmail.com' ||
        request.auth.uid == 'CrlADj8aKWXjP9oZGX7kZEWVoCD3'
      );
    }
    
    // --- COMPREHENSIVE SECURITY HELPERS ---

    // 0. Owner Check (Metadata)
    function isSiteOwner(siteId) {
       let siteData = get(/databases/$(database)/documents/sites/$(siteId)).data;
       return request.auth != null && (siteData.ownerId == request.auth.uid || siteData.ownerEmail == request.auth.token.email);
    }

    // 1. Valid Active User Check (Status must be 'active')
    function isValidUser(siteId) {
       return request.auth != null && (
         isGlobalAdmin() ||
         isSiteOwner(siteId) ||
         (
           exists(/databases/$(database)/documents/sites/$(siteId)/members/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/sites/$(siteId)/members/$(request.auth.uid)).data.status == 'active'
         )
       );
    }

    // 2. Strict Modularity Check (Module must be true in site settings)
    function isModuleEnabled(siteId, moduleKey) {
      // Check global admin OR check site settings
      return isGlobalAdmin() || (
         get(/databases/$(database)/documents/sites/$(siteId)).data.modules[moduleKey] == true
      );
    }

    // 3. Role-Based Access Control (Granular)
    function hasRole(siteId, allowedRoles) {
      // Check global admin OR site owner OR check user role (with exists guard)
      return isGlobalAdmin() || isSiteOwner(siteId) || (
        exists(/databases/$(database)/documents/sites/$(siteId)/members/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/sites/$(siteId)/members/$(request.auth.uid)).data.role in allowedRoles
      );
    }

    // Shortcut for Owner Only
    function isOwner(siteId) {
      return hasRole(siteId, ['owner']);
    }

    // --- GRANULAR PERMISSION CHECKS ---
    
    // Get Member Data Helper
    function getMemberData(siteId) {
      return get(/databases/$(database)/documents/sites/$(siteId)/members/$(request.auth.uid)).data;
    }

    // Check if user has FULL access to a specific module/route
    function hasWritePermission(siteId, moduleId, routeId) {
      return isGlobalAdmin() || isSiteOwner(siteId) || (
         isValidUser(siteId) && (
            // 1. Check Granular Access (moduleAccess)
            // Function maps must be safe access. 
            // moduleAccess[moduleId][routeId] == 'full'
            (
              getMemberData(siteId).moduleAccess != null &&
              getMemberData(siteId).moduleAccess[moduleId] != null &&
              getMemberData(siteId).moduleAccess[moduleId][routeId] == 'full'
            ) ||
            // 2. Legacy Permission Array Check (Fallback if granular not set)
            // User has 'moduleId' in permissions list
            (
               (getMemberData(siteId).moduleAccess == null || getMemberData(siteId).moduleAccess[moduleId] == null) &&
               getMemberData(siteId).permissions.hasAny([moduleId, moduleId + ':full'])
            )
          )
      );
    }

    // --- LEGACY HELPER ---
    function hasSiteAccess(siteId) {
       return isValidUser(siteId);
    }

    // --- ROOT COLLECTIONS ---
    
    // Users Collection - User Profile & Subcollections
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isGlobalAdmin());
      match /{document=**} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isGlobalAdmin());
      }
    }
    
    // Modules Registry
    match /modules/{moduleId} {
      allow read: if true;
      allow write: if isGlobalAdmin() || request.auth != null;
    }

    // Templates Registry
    match /templates/{templateId} {
        allow read: if true;
        allow write: if isGlobalAdmin() || request.auth != null;
    }
    
    // Slug Mappings (Routing)
    match /slugMappings/{slug} {
      allow read: if true;
      allow write: if isGlobalAdmin();
    }

    // --- MULTI-TENANT SITE LAYER ---
    match /sites/{siteId} {
      
      // SITE METADATA
      allow get: if true; // Public read needed for middleware/routing
      allow list: if isGlobalAdmin() || (request.auth != null && (resource.data.ownerId == request.auth.uid || resource.data.ownerEmail == request.auth.token.email)); 
      allow write: if isGlobalAdmin();

      // === SYSTEM COLLECTIONS ===

      // MEMBERS (System Users)
      // Access: Owners (Metadata), Active Members (Read), Managers (Write)
      match /members/{memberId} {
        allow read, write: if isGlobalAdmin() || isSiteOwner(siteId);
        allow read: if isValidUser(siteId);
        allow read: if request.auth != null && request.auth.uid == memberId;
        allow create, update: if isValidUser(siteId) && hasRole(siteId, ['owner']);
        allow delete: if isValidUser(siteId) && isOwner(siteId);
      }

      // INVITATIONS
      match /invitations/{email} {
        allow read, write: if isValidUser(siteId) && hasRole(siteId, ['owner']);
        allow read: if request.auth.token.email == email;
      }
      
      // SETTINGS (Site Config)
      match /settings/{settingId} {
        allow read: if true;
        allow write: if isValidUser(siteId) && isOwner(siteId);
      }

      // ANALYTICS (Read only by authenticated staff, except siteStats for tracking)
      match /analytics/siteStats {
        allow read: if true;
        allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pageViews', 'totalClicks']);
        allow create: if request.resource.data.keys().hasOnly(['pageViews', 'totalClicks']);
      }
      match /analytics/{docId} {
        allow read: if hasSiteAccess(siteId);
        allow write: if false; // Server-side only
      }

      // ANALYTICS SHARDS (Distributed counters — replaces siteStats for high-throughput writes)
      match /analytics_shards/{shardId} {
        allow read: if hasSiteAccess(siteId);
        allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pageViews', 'totalClicks']);
        allow create: if request.resource.data.keys().hasOnly(['pageViews', 'totalClicks']);
      }

      // === CORE CMS CONTENT ===
      // Pages, Content, Posts, Products, Links, Forms, Branches
      
      match /pages/{pageId} { allow read: if true; allow write: if hasSiteAccess(siteId); }
      match /pages_trash/{pageId} { allow read, write: if hasSiteAccess(siteId); }
      match /content/{docId} { allow read: if true; allow write: if hasSiteAccess(siteId); }
      match /posts/{postId} { allow read: if true; allow write: if hasSiteAccess(siteId); }
      match /products/{productId} { 
        allow read: if true; 
        allow update: if hasSiteAccess(siteId) || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clicks']);
        allow create, delete: if hasSiteAccess(siteId);
      }
      match /links/{linkId} { 
        allow read: if true; 
        allow update: if hasSiteAccess(siteId) || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clicks']);
        allow create, delete: if hasSiteAccess(siteId);
      }
      match /forms/{formId} { allow read: if true; allow write: if hasSiteAccess(siteId); }
      match /branches/{branchId} { allow read: if true; allow write: if hasSiteAccess(siteId); }

      // SERVICE CATALOG (Shared master data — referenced by Reservation + Service Records)
      match /serviceCatalog/{itemId} {
        allow read: if true;
        allow write: if hasSiteAccess(siteId);
      }

      // INBOX (Form Submissions) - Public Create
      match /inbox/{messageId} {
        allow create: if true;
        allow read, update, delete: if hasSiteAccess(siteId);
      }

      // === LEGACY ROOT MODULES ===
      // (Must stay at root due to existing data/code)

      // LEADS (Sales Pipeline)
      match /leads/{leadId} {
        allow read, write: if isValidUser(siteId) && isModuleEnabled(siteId, 'sales_pipeline') && hasRole(siteId, ['owner', 'staff']);
      }

      // Sales Pipeline — API uses MODULE_ID = 'sales_pipeline' (underscore)
      match /modules/sales_pipeline/{document=**} {
         allow read: if isValidUser(siteId) && isModuleEnabled(siteId, 'sales_pipeline') && hasRole(siteId, ['owner', 'staff']);
         allow write: if isValidUser(siteId) && isModuleEnabled(siteId, 'sales_pipeline') && hasRole(siteId, ['owner', 'staff']);
      }

      // === STRICT NESTED MODULES ===
      
      // 1. BYOD POS
      match /modules/byod_pos/settings/{settingId} {
        allow read: if true;
        allow write: if hasWritePermission(siteId, 'pos', 'configuration');
      }
      match /modules/byod_pos/menu_items/{itemId} {
        allow read: if true;
        allow write: if hasWritePermission(siteId, 'pos', 'menu_manager');
      }
      match /modules/byod_pos/categories/{categoryId} {
        allow read: if true;
        allow write: if hasWritePermission(siteId, 'pos', 'menu_manager');
      }
      match /modules/byod_pos/orders/{orderId} {
        allow create: if true;
        allow get: if request.auth != null;
        allow list: if request.auth != null && (resource.data.creatorId == request.auth.uid || hasSiteAccess(siteId));
        allow update, delete: if request.auth != null && (resource.data.creatorId == request.auth.uid || hasSiteAccess(siteId));
      }

      // 2. RESERVATION
      match /modules/reservation/services/{serviceId} {
        allow read: if true;
        allow write: if hasSiteAccess(siteId);
      }
      match /modules/reservation/slots/{slotId} {
        allow read: if true;
        allow write: if hasSiteAccess(siteId);
      }
      match /modules/reservation/bookings/{bookingId} {
        allow create: if true;
        allow read, update, delete: if hasSiteAccess(siteId);
      }
      match /modules/reservation/settings/{settingId} {
        allow read: if true;
        allow write: if hasSiteAccess(siteId);
      }
      
      // Catch-all for other reservation docs (like setup/config)
      match /modules/reservation/{document=**} {
         allow read: if true;
         allow write: if hasSiteAccess(siteId);
      }

      // 3. INVENTORY (Strictly Nested)
      match /modules/inventory/items/{itemId} {
        allow read: if isValidUser(siteId) && isModuleEnabled(siteId, 'inventory');
        allow write: if hasWritePermission(siteId, 'inventory', 'main');
      }
      match /modules/inventory/transactions/{txnId} {
        allow read: if isValidUser(siteId) && isModuleEnabled(siteId, 'inventory');
        allow write: if hasWritePermission(siteId, 'inventory', 'main');
      }

      // 3b. STOCKLENS (AI inventory scanner)
      // SKUs and unit sub-collection: tenant staff can read/write when module enabled
      match /modules/stocklens/skus/{skuId} {
        allow read: if isValidUser(siteId) && isModuleEnabled(siteId, 'stocklens');
        allow write: if hasWritePermission(siteId, 'stocklens', 'main');

        match /units/{unitId} {
          allow read: if isValidUser(siteId) && isModuleEnabled(siteId, 'stocklens');
          allow write: if hasWritePermission(siteId, 'stocklens', 'main');
        }
      }
      // Private config (Gemini API key) — server-only via Admin SDK; deny client access
      match /modules/stocklens/private/{configId} {
        allow read, write: if false;
      }

      // 4. MEMBERSHIP (Strictly Nested)
      match /modules/membership/members/{memberId} {
        allow read: if isModuleEnabled(siteId, 'membership') && (
            isValidUser(siteId) || 
            (request.auth != null && (resource.data.email == request.auth.token.email || resource.data.uid == request.auth.uid))
        );
        allow update: if isModuleEnabled(siteId, 'membership') && (
            hasWritePermission(siteId, 'membership', 'members') ||
            (request.auth != null && resource.data.email == request.auth.token.email) // Self-link uid
        );
        allow create, delete: if hasWritePermission(siteId, 'membership', 'members');
      }
      match /modules/membership/transactions/{txnId} {
        allow read: if isModuleEnabled(siteId, 'membership') && (
            isValidUser(siteId) || 
            (request.auth != null && get(/databases/$(database)/documents/sites/$(siteId)/modules/membership/members/$(resource.data.memberId)).data.uid == request.auth.uid)
        );
        allow write: if hasWritePermission(siteId, 'membership', 'transactions'); // Usually system writes
      }
      match /modules/membership/settings/{settingId} {
        allow read: if isValidUser(siteId) && isModuleEnabled(siteId, 'membership');
        allow write: if hasWritePermission(siteId, 'membership', 'settings');
      }

      // 5. SERVICE RECORDS (Strictly Nested)
      match /modules/service_records/serviceRecords/{recordId} {
        allow read: if isValidUser(siteId) && isModuleEnabled(siteId, 'service_records');
        allow create: if isValidUser(siteId) && isModuleEnabled(siteId, 'service_records');
        allow update: if isValidUser(siteId) && isModuleEnabled(siteId, 'service_records');
        allow delete: if isOwner(siteId);
      }
      match /modules/service_records/vehicles/{vehicleId} {
        allow read: if isValidUser(siteId) && isModuleEnabled(siteId, 'service_records');
        allow write: if isValidUser(siteId) && isModuleEnabled(siteId, 'service_records');
      }
      match /modules/service_records/serviceTypes/{typeId} {
        allow read: if isValidUser(siteId) && isModuleEnabled(siteId, 'service_records');
        allow write: if isOwner(siteId) && isModuleEnabled(siteId, 'service_records');
      }
      match /modules/service_records/warrantyCards/{cardId} {
        allow read: if true; // Public — also accessed via collectionGroup on /warranty/{code}
        allow create: if isValidUser(siteId) && isModuleEnabled(siteId, 'service_records');
        allow update: if isOwner(siteId) && isModuleEnabled(siteId, 'service_records'); // void only
        allow delete: if false;
      }
      match /modules/service_records/reminderQueue/{entryId} {
        allow read: if isOwner(siteId) && isModuleEnabled(siteId, 'service_records');
        allow write: if isValidUser(siteId) && isModuleEnabled(siteId, 'service_records');
      }
      match /modules/service_records/serviceConfig/{configId} {
        allow read: if isValidUser(siteId) && isModuleEnabled(siteId, 'service_records');
        allow write: if isOwner(siteId) && isModuleEnabled(siteId, 'service_records');
      }
      match /modules/service_records/carCatalog/{entryId} {
        allow read: if isValidUser(siteId) && isModuleEnabled(siteId, 'service_records');
        allow write: if isValidUser(siteId) && isModuleEnabled(siteId, 'service_records');
      }

      // 6. PROMO ENGINE
      match /modules/promo/promos/{promoId} {
        allow read: if true; // Public — customers need to read active promos for auto-apply and code evaluation
        allow write: if isValidUser(siteId) && hasRole(siteId, ['owner', 'staff']);
      }
      match /modules/promo/vouchers/{voucherId} {
        allow read: if isModuleEnabled(siteId, 'promo') && (
          isValidUser(siteId) ||
          (request.auth != null && resource.data.ownerMemberId != null) // member can read own vouchers
        );
        allow write: if isValidUser(siteId) && hasRole(siteId, ['owner', 'staff']);
      }
      match /modules/promo/settings/{settingId} {
        allow read: if true; // Public — needed for allowGuestCodes check during evaluation
        allow write: if isValidUser(siteId) && hasRole(siteId, ['owner']);
      }

      // 7. AI SALES AGENT (Strictly Nested)
      match /modules/ai_sales {
        allow read: if true; // Public needs to read config (enabled/greeting)
        allow write: if isValidUser(siteId) && hasRole(siteId, ['owner']);
        
        // Allow deep read for config/subcollections
        match /{document=**} {
             allow read: if isValidUser(siteId);
             allow write: if isValidUser(siteId) && hasRole(siteId, ['owner']);
        }
      }

      // Note: Generic "Catch-all" REMOVED to enforce strict modularity.
      // Every module must be explicitly defined above.

      // === WHATSAPP CORE ===
      // WA is core infrastructure (not a module) — lives at sites/{siteId}/wa/

      // Config doc — all active members can read (access token encrypted server-side)
      // Path: sites/{siteId}/wa/config
      match /wa/config {
        allow read: if isValidUser(siteId);
        allow write: if false; // Server-side only via /api/admin/whatsapp/connect
      }

      // All subcollections live under sites/{siteId}/wa/main/
      match /wa/main {
        allow read: if isValidUser(siteId);
        allow write: if false;

        // Customer threads
        match /customer_threads/{threadId} {
          allow read, update, create: if isValidUser(siteId);
          allow delete: if false;
          match /messages/{msgId} {
            allow read: if isValidUser(siteId);
            allow write: if false;
          }
        }

        // Staff commands — owner only
        match /staff_commands/{threadId} {
          allow read: if isValidUser(siteId) && isOwner(siteId);
          allow write: if false;
          match /messages/{msgId} {
            allow read: if isValidUser(siteId) && isOwner(siteId);
            allow write: if false;
          }
        }

        // Contacts directory
        match /contacts/{contactId} {
          allow read: if isValidUser(siteId);
          allow write: if isValidUser(siteId) && isOwner(siteId);
        }

        // Templates
        match /templates/{templateId} {
          allow read: if isValidUser(siteId);
          allow write: if isValidUser(siteId) && isOwner(siteId);
        }

        // Raw messages — audit trail
        match /raw_messages/{msgId} {
          allow read: if isValidUser(siteId) && isOwner(siteId);
          allow write: if false;
        }
      }
    }
    
    // === COLLECTION GROUP QUERIES ===

    // Public warranty card lookup (/warranty/{code} page — no auth required)
    match /{path=**}/warrantyCards/{cardId} {
      allow read: if true;
    }

    match /{path=**}/members/{memberId} {
      allow read: if request.auth != null && (
        resource.data.email == request.auth.token.email || 
        request.auth.uid == memberId
      );
    }

    // === PLATFORM MONITORING ===

    // platform_logs — write only from server (admin SDK bypasses rules)
    // read only by superadmin
    match /platform_logs/{logId} {
      allow read: if isGlobalAdmin();
      allow write: if false;
    }

    // emailLog (collection group) — superadmin only, for backyard Resend monitoring
    // Writes go through admin SDK in clicker-platform-v2 (bypasses rules).
    match /{path=**}/emailLog/{logId} {
      allow read: if isGlobalAdmin();
      allow write: if false;
    }

    // platform_meta — seed history and future meta docs
    match /platform_meta/{docId} {
      allow read: if isGlobalAdmin();
      allow write: if isGlobalAdmin();
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
