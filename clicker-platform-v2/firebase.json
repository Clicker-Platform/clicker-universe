{
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "!**/.env.local",
      "!**/.env.production",
      "!**/.env",
      "**/node_modules/**"
    ],
    "site": "aletraid",
    "frameworksBackend": {
      "region": "us-central1"
    }
  }
}