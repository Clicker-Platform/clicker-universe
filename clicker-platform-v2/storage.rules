rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Auth helper
    function isAuthenticated() {
      return request.auth != null;
    }

    // Default: Public Read for everything (simplified for now)
    match /{allPaths=**} {
      allow read: if true;
    }

    // Digital Goods product files — signed-URL-only (no direct public read)
    // MUST be above the wildcard /sites/{siteId}/{allPaths=**} rule
    match /sites/{siteId}/modules/digital_goods/products/files/{allPaths=**} {
      allow read: if false;
      allow write: if isAuthenticated();
    }

    // Tenant Writes: /sites/{siteId}/...
    match /sites/{siteId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Legacy Writes: /products/...
    match /products/{allPaths=**} {
      allow write: if isAuthenticated();
    }

    // Legacy Writes: /uploads/...
    match /uploads/{allPaths=**} {
      allow write: if isAuthenticated();
    }
  }
}
