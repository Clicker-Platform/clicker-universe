rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Auth helper
    function isAuthenticated() {
      return request.auth != null;
    }

    // Default: Public Read for everything (simplified for now)
    match /{allPaths=**} {
      allow read: if true;
    }

    // Tenant Writes: /sites/{siteId}/...
    match /sites/{siteId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && (
        firestore.get(/databases/(default)/documents/sites/$(siteId)).data.ownerId == request.auth.uid ||
        firestore.exists(/databases/(default)/documents/sites/$(siteId)/members/$(request.auth.uid))
      );
    }

    // Legacy Writes: /products/...
    match /products/{allPaths=**} {
      allow write: if isAuthenticated();
    }

    // Legacy Writes: /uploads/...
    match /uploads/{allPaths=**} {
      allow write: if isAuthenticated();
    }
  }
}
