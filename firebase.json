{
    "firestore": {
        "rules": "clicker-platform-v2/firestore.rules",
        "indexes": "clicker-platform-v2/firestore.indexes.json"
    },
    "storage": {
        "rules": "clicker-platform-v2/storage.rules"
    },
    "functions": {
        "source": "functions",
        "codebase": "default",
        "ignore": [
            "node_modules",
            ".git",
            "firebase-debug.log",
            "firebase-debug.*.log"
        ]
    },
    "hosting": [
        {
            "target": "core",
            "source": "clicker-platform-v2",
            "ignore": [
                "firebase.json",
                "**/.*",
                "**/node_modules/**"
            ],
            "frameworksBackend": {
                "region": "us-central1",
                "memory": "1GiB"
            }
        },
        {
            "target": "auth",
            "source": "auth-gateway",
            "ignore": [
                "firebase.json",
                "**/.*",
                "**/node_modules/**"
            ],
            "frameworksBackend": {
                "region": "us-central1",
                "memory": "1GiB"
            }
        },
        {
            "target": "backyard",
            "source": "backyard",
            "ignore": [
                "firebase.json",
                "**/.*",
                "**/node_modules/**"
            ],
            "frameworksBackend": {
                "region": "us-central1",
                "memory": "1GiB"
            }
        },
        {
            "target": "website",
            "source": "clicker-website",
            "ignore": [
                "firebase.json",
                "**/.*",
                "**/node_modules/**"
            ],
            "frameworksBackend": {
                "region": "us-central1",
                "memory": "512MiB"
            }
        }
    ],
    "emulators": {
        "auth": {
            "host": "127.0.0.1",
            "port": 9099
        },
        "functions": {
            "host": "127.0.0.1",
            "port": 5001
        },
        "firestore": {
            "host": "127.0.0.1",
            "port": 8080
        },
        "ui": {
            "enabled": true
        }
    }
}