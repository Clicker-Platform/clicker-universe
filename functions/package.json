        "deploy": "firebase deploy --only functions",
        "logs": "firebase functions:log"
    },
    "engines": {
        "node": "22"
    },
    "main": "lib/index.js",
    "dependencies": {
        "@google-cloud/functions-framework": "^3.5.1",
        "firebase-admin": "^13.6.0",
        "firebase-functions": "^7.0.3",
        "sharp": "0.34.5"
    },
    "devDependencies": {
        "firebase-functions-test": "^3.1.0",
        "typescript": "^4.9.0"
    },
    "private": true
}