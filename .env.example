# Clicker Universe — Environment Variables Example
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or real keys to git.

# ─────────────────────────────────────────────────
# Base Domain
# ─────────────────────────────────────────────────
# Production: clicker.id  |  Staging: stg-clicker-core.web.app
NEXT_PUBLIC_BASE_DOMAIN=clicker.id

# ─────────────────────────────────────────────────
# Firebase Client SDK (clicker-platform-v2)
# ─────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# ─────────────────────────────────────────────────
# Firebase Admin SDK (Server-side ONLY)
# Contains the JSON content of your service account key.
# DO NOT prefix with NEXT_PUBLIC_
# ─────────────────────────────────────────────────
# Option A (recommended for local dev): relative path to key file (NOT committed)
#   GCP_SERVICE_ACCOUNT_KEY=../scripts/your-service-account.json
# Option B (production / inline): full JSON string on a single line
#   GCP_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
GCP_SERVICE_ACCOUNT_KEY=../scripts/your-service-account.json

# ─────────────────────────────────────────────────
# Auth Gateway
# ─────────────────────────────────────────────────
# Production: https://auth.clicker.id  |  Local: http://localhost:3012
NEXT_PUBLIC_AUTH_GATEWAY_URL=http://localhost:3012

# ─────────────────────────────────────────────────
# Cache — Upstash Redis (optional but recommended)
# If absent, cache is skipped and Firestore is hit directly.
# ─────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─────────────────────────────────────────────────
# WhatsApp Integration
# ─────────────────────────────────────────────────
WA_WEBHOOK_VERIFY_TOKEN=your-verify-token
WA_ENCRYPTION_KEY=your-encryption-key-32-chars-min

# ─────────────────────────────────────────────────
# AI / LLM
# ─────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
