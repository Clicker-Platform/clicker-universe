# Normalize line endings
* text=auto

# JavaScript / TypeScript
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.mjs text eol=lf
*.mts text eol=lf
*.json text eol=lf

# Styles
*.css text eol=lf
*.scss text eol=lf

# Markup
*.html text eol=lf
*.md text eol=lf
*.mdx text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf

# Shell scripts
*.sh text eol=lf

# Config
.env* text eol=lf
*.config.* text eol=lf
Makefile text eol=lf

# Binary assets — do not diff
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary

# AI context — exclude from LLM indexing (sensitive files)
clicker-universe-stagging-firebase-adminsdk-*.json linguist-generated=true
*firebase-adminsdk*.json linguist-generated=true
*.bak linguist-generated=true
pnpm-lock.yaml linguist-generated=true
package-lock.json linguist-generated=true
